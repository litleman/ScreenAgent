{
  "name": "screen-agent",
  "version": "0.1.3",
  "description": "桌面 GUI 视觉代理引擎 — 让 AI 看懂并操作任何 Windows 软件",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "screen-agent": "bin/screen-agent.js",
    "screen-agent-configure": "bin/screen-agent-configure.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "vision",
    "requirements.txt",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "prepare": "pip install -r \"%~dp0requirements.txt\" 2>nul || echo 跳过 Python 依赖安装",
    "setup": "pip install -r requirements.txt && python scripts/check.py && node scripts/configure.mjs --all",
    "configure": "node scripts/configure.mjs",
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run setup",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litleman/ScreenAgent.git"
  },
  "keywords": [
    "mcp",
    "screen-agent",
    "gui-agent",
    "desktop-automation",
    "computer-use",
    "vision",
    "uia",
    "ocr",
    "windows"
  ],
  "author": "litleman",
  "license": "MIT",
  "dependencies": {
    "@harusame64/desktop-touch-mcp": "^1.9.2",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
